# ── Backend ────────────────────────────────────────────────
# FastAPI port
PORT=5000

# Optional: provide an OpenAI key to enable LLM explanations
# in the AI Agent (will gracefully degrade to template if absent)
OPENAI_API_KEY=

# ── Qdrant Vector DB ───────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Kafka ──────────────────────────────────────────────────
KAFKA_BOOTSTRAP=localhost:9092

# ── Frontend (Vite) ────────────────────────────────────────
# Only needed if FastAPI is on a non-standard port
VITE_API_PORT=5000
